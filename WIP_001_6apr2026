void drawOtaScreen(int pct, const String& msg) {
  display.clearDisplay();
  resetDisplayState();

  display.setCursor(0, 0);
  display.print("OTA UPDATE");

  display.setCursor(0, 14);
  display.print(msg);

  display.setCursor(0, 28);
  display.print("Progress: ");
  display.print(pct);
  display.print("%");

  int barX = 0, barY = 44, barW = 128, barH = 10;
  display.drawRect(barX, barY, barW, barH, SH110X_WHITE);
  int fillW = (pct * (barW - 2)) / 100;
  if (fillW < 0) fillW = 0;
  if (fillW > (barW - 2)) fillW = barW - 2;
  display.fillRect(barX + 1, barY + 1, fillW, barH - 2, SH110X_WHITE);

  display.setCursor(0, 58);
  display.print("Do not power off");
  display.display();
}

void setupOTA() {
  if (!MDNS.begin(OTA_HOSTNAME)) {
    
    otaEnabled = false;
    return;
  }

  ArduinoOTA.setHostname(OTA_HOSTNAME);
  ArduinoOTA.setPassword(OTA_PASSWORD);

  ArduinoOTA.onStart([]() {
    otaInProgress = true;
    otaPercent = 0;
    otaStatus = "Starting...";
    
    drawOtaScreen(otaPercent, otaStatus);
  });

  ArduinoOTA.onProgress([](unsigned int progress, unsigned int total) {
    int pct = (total > 0) ? (int)((progress * 100) / total) : 0;
    if (pct != otaPercent) {
      otaPercent = pct;
      otaStatus = "Updating...";
      
      drawOtaScreen(otaPercent, otaStatus);
    }
  });

  ArduinoOTA.onEnd([]() {
    otaPercent = 100;
    otaStatus = "Done. Rebooting";
    
    drawOtaScreen(otaPercent, otaStatus);
    delay(500);
    otaInProgress = false;
  });

  ArduinoOTA.onError([](ota_error_t error) {
    otaInProgress = false;
    otaStatus = "OTA Error: " + String((int)error);
    
    drawOtaScreen(otaPercent, otaStatus);
    delay(1500);
  });

  ArduinoOTA.begin();
  otaEnabled = true;

}

