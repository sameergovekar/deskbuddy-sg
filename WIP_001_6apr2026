void initEye(EyeData& e, float _x, float _y, float _w, float _h) {
  e.x = e.targetX = _x;
  e.y = e.targetY = _y;
  e.w = e.targetW = _w;
  e.h = e.targetH = _h;
  e.pupilX = e.targetPupilX = 0;
  e.pupilY = e.targetPupilY = 0;
  e.velX = e.velY = e.velW = e.velH = 0;
  e.pVelX = e.pVelY = 0;
  e.blinking = false;
  e.lastBlink = 0;
  e.nextBlinkTime = millis() + random(1000, 4000);
}

void updateEye(EyeData& e) {
  float ax = (e.targetX - e.x) * e.k;
  float ay = (e.targetY - e.y) * e.k;
  float aw = (e.targetW - e.w) * e.k;
  float ah = (e.targetH - e.h) * e.k;

  e.velX = (e.velX + ax) * e.d;
  e.velY = (e.velY + ay) * e.d;
  e.velW = (e.velW + aw) * e.d;
  e.velH = (e.velH + ah) * e.d;

  e.x += e.velX;
  e.y += e.velY;
  e.w += e.velW;
  e.h += e.velH;

  float pax = (e.targetPupilX - e.pupilX) * e.pk;
  float pay = (e.targetPupilY - e.pupilY) * e.pk;
  e.pVelX = (e.pVelX + pax) * e.pd;
  e.pVelY = (e.pVelY + pay) * e.pd;
  e.pupilX += e.pVelX;
  e.pupilY += e.pVelY;
}

