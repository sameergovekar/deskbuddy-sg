void drawWrappedText(String text, int x, int y, int maxCharsPerLine, int lineHeight, int maxLines) {
  int start = 0;
  int line = 0;

  while (start < text.length() && line < maxLines) {
    int end = start + maxCharsPerLine;
    if (end >= text.length()) {
      end = text.length();
    } else {
      int lastSpace = text.lastIndexOf(' ', end);
      if (lastSpace > start) end = lastSpace;
    }

    String part = text.substring(start, end);
    part.trim();
    display.setCursor(x, y + line * lineHeight);
    display.print(part);

    start = end + 1;
    line++;
  }
}

String shortenTitle(String text, int maxLen) {
  if (text.length() <= maxLen) return text;
  return text.substring(0, maxLen - 1) + ".";
}

