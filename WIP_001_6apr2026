  if (mood == "normal") return MOOD_NORMAL;
  if (mood == "happy") return MOOD_HAPPY;
  if (mood == "surprised") return MOOD_SURPRISED;
  if (mood == "sleepy") return MOOD_SLEEPY;
  if (mood == "angry") return MOOD_ANGRY;
  if (mood == "sad") return MOOD_SAD;
  if (mood == "excited") return MOOD_EXCITED;
  if (mood == "love") return MOOD_LOVE;
  if (mood == "suspicious") return MOOD_SUSPICIOUS;
  return -1;
}

