void setup() {
  Serial.begin(115200);
  delay(150);

  Wire.begin(SDA_PIN, SCL_PIN);
  pinMode(TOUCH_PIN, INPUT);

  display.begin(0x3C, true);
  resetDisplayState();
  drawBootScreen();

  randomSeed(millis());
  initRain();
  lastInteractionTime = millis();
  pomodoroStart = millis();
  lastAutoPageSwitch = millis();

  loadConfig();

  
  delay(600);  // let touch sensor settle after power-up

  bool forceConfig = false;
  unsigned long pressedSince = 0;
  unsigned long bootCheckStart = millis();
  const unsigned long BOOT_WINDOW_MS = CONFIG_HOLD_MS + 700;

  while (millis() - bootCheckStart < BOOT_WINDOW_MS) {
    bool pressed = digitalRead(TOUCH_PIN);   // active HIGH touch

    if (pressed) {
      if (pressedSince == 0) pressedSince = millis();
      if (millis() - pressedSince >= CONFIG_HOLD_MS) {
        forceConfig = true;
        break;
      }
    } else {
      pressedSince = 0;
    }

    delay(30);
  }

  if (forceConfig || !hasSavedWifi) {
    
    startConfigPortal();
    return;
  }

  initEye(leftEye, 18, 14, 36, 36);
  initEye(rightEye, 74, 14, 36, 36);

  playBootAnimation();

  display.clearDisplay();
  resetDisplayState();
  display.setCursor(28, 30);
  display.print("Connecting WiFi");
  display.display();

  if (!connectWiFiFast()) {
    
    display.clearDisplay();
    resetDisplayState();
    display.setCursor(0, 18);
    display.print("WiFi failed");
    display.setCursor(0, 34);
    display.print("Hold touch for setup");
    display.display();
    delay(2000);
    startConfigPortal();
    return;
  }


  setupOTA();

  configTime(0, 0, ntpServer);
  setenv("TZ", tzString.c_str(), 1);
  tzset();

  struct tm timeinfo;
  int tries = 0;
  while (!getLocalTime(&timeinfo) && tries < 20) {
    delay(500);
    tries++;
  }

  getWeatherAndForecast();
  fetchAIMessage("weather_refresh");
  fetchCalendarStatus();
  fetchHinduCalendar();

  lastWeatherUpdate = millis();
  lastCalendarFetch = millis();
  lastHinduFetch = millis();
}

void loop() {
  if (inConfigMode) {
    configServer.handleClient();
    return;
  }

  if (otaEnabled) {
    ArduinoOTA.handle();
    if (otaInProgress) return;
  }

  unsigned long now = millis();

  handleTouch();
  updatePomodoro();

  if (calendarMarqueeText.length() > 0) {
    int charWidth = 6;
    int totalWidth = calendarMarqueeText.length() * charWidth;

    if (marqueePaused) {
      if (millis() - marqueePauseStart >= MARQUEE_PAUSE_MS) {
        marqueePaused = false;
      }
    } else if (millis() - lastMarqueeStep > MARQUEE_STEP_MS) {
      marqueeOffset += 2;
      lastMarqueeStep = millis();

      if (marqueeOffset >= totalWidth) {
        marqueeOffset = 0;
        marqueePaused = true;
        marqueePauseStart = millis();
      }
    }
  }

  if (now - lastWeatherUpdate > 600000) {
    getWeatherAndForecast();
    lastWeatherUpdate = now;
  }

  if (now - lastCalendarFetch > CALENDAR_REFRESH_MS) {
    fetchCalendarStatus();
    lastCalendarFetch = now;
  }

  if (now - lastHinduFetch > HINDU_REFRESH_MS) {
    fetchHinduCalendar();
    lastHinduFetch = now;
  }

  updateMoodByWiFiAndIdle();
  refreshEffectiveMood();

  int maxPage = 7;

  if (now - lastAutoPageSwitch > getCurrentPageDuration()) {
    currentPage++;
    if (currentPage > maxPage) currentPage = 0;
    lastAutoPageSwitch = now;
    lastSaccade = 0;
  }

  display.clearDisplay();

  switch (currentPage) {
    case 0: drawEmoPage(); break;
    case 1: drawClock(); break;
    case 2: drawWeatherCard(); break;
    case 3: drawForecastPage(); break;
    case 4: drawPomodoroPage(); break;
    case 5: drawCalendarPage(); break;
    case 6:
      if (aiMessageAvailable) drawAIPage();
      else drawHinduCalendarPage();
      break;
    case 7: drawHinduCalendarPage(); break;
  }

  display.display();
}
