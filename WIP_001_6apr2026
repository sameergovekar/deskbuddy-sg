void drawClock() {
  resetDisplayState();

  struct tm t;
  if (!getLocalTime(&t)) {
    display.setCursor(30, 30);
    display.print("Syncing...");
    return;
  }

  int h12 = t.tm_hour % 12;
  if (h12 == 0) h12 = 12;

  const char* ampm = (t.tm_hour >= 12) ? "PM" : "AM";

  // Time in existing large font
  display.setFont(&FreeSansBold18pt7b);
  char timeStr[6];
  sprintf(timeStr, "%02d:%02d", h12, t.tm_min);

  int16_t x1, y1;
  uint16_t wTime, hTime;
  display.getTextBounds(timeStr, 0, 0, &x1, &y1, &wTime, &hTime);

  // AM/PM in default font
  display.setFont(NULL);
  uint16_t wAmpm, hAmpm;
  display.getTextBounds(ampm, 0, 0, &x1, &y1, &wAmpm, &hAmpm);

  // Center whole group: time + gap + ampm
  int totalWidth = wTime + 4 + wAmpm;
  int startX = (SCREEN_WIDTH - totalWidth) / 2;

  // Draw time
  display.setFont(&FreeSansBold18pt7b);
  display.setCursor(startX, 40);
  display.print(timeStr);

  // Draw AM/PM beside time, slightly higher
  display.setFont(NULL);
  display.setCursor(startX + wTime + 4, 30);
  display.print(ampm);

  // Date line
  char dateStr[20];
  strftime(dateStr, sizeof(dateStr), "%a, %b %d", &t);
  uint16_t wDate, hDate;
  display.getTextBounds(dateStr, 0, 0, &x1, &y1, &wDate, &hDate);
  display.setCursor((SCREEN_WIDTH - wDate) / 2, 54);
  display.print(dateStr);

  drawWiFiIndicatorAt(110, 10, false);
}

