void updateMoodByWiFiAndIdle() {
  wifiBars = getWiFiBars();
  wifiWeak = (wifiBars <= 1);

  unsigned long now = millis();
  if (now - lastInteractionTime > IDLE_SLEEP_MS) {
    localMood = MOOD_SLEEPY;
    return;
  }

  if (WiFi.status() != WL_CONNECTED) {
    localMood = MOOD_SAD;
    return;
  }

  if (wifiWeak) {
    localMood = MOOD_SUSPICIOUS;
    return;
  }
}

