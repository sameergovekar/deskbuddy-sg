void applyAIResponse(JSONVar resp, String trigger) {
  if (JSON.typeof(resp) == "undefined") return;
  String status = (const char*)resp["status"];
  if (status != "ok") return;

  if (resp.hasOwnProperty("message")) {
    aiMessage = (const char*)resp["message"];
    aiMessage.trim();
    if (aiMessage.length() > 0) {
      aiMessageAvailable = true;
      aiLastTrigger = trigger;
    }
  }

  int showSeconds = 8;
  if (resp.hasOwnProperty("show_seconds")) {
    showSeconds = int(resp["show_seconds"]);
    if (showSeconds <= 0) showSeconds = 8;
  }

  if (resp.hasOwnProperty("mood")) {
    String moodStr = (const char*)resp["mood"];
    int m = moodFromString(moodStr);
    if (m >= 0) {
      aiMoodOverride = m;
      aiMoodOverrideUntil = millis() + (unsigned long)showSeconds * 1000UL;
    }
  }
}

void fetchAIMessage(String trigger) {
  if (WiFi.status() != WL_CONNECTED) return;
  if (AI_SERVER.length() == 0) return;

  unsigned long now = millis();
  if (now - lastAiFetch < AI_MIN_INTERVAL_MS &&
      trigger != "boot" &&
      trigger != "weather_refresh" &&
      trigger != "pomodoro_break_start" &&
      trigger != "pomodoro_focus_start") {
    return;
  }

  HTTPClient http;
  String url = AI_SERVER + "/deskbuddy-message";
  http.setTimeout(AI_HTTP_TIMEOUT_MS);
  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  String payload = "{";
  payload += "\"city\":\"" + city + "\",";
  payload += "\"weather\":\"" + weatherMain + "\",";
  payload += "\"temp\":" + String((int)temperature) + ",";
  payload += "\"humidity\":" + String(humidity) + ",";
  payload += "\"wifi_bars\":" + String(wifiBars) + ",";
  payload += "\"mode\":\"" + currentModeString() + "\",";
  payload += "\"time_of_day\":\"" + getTimeBucket() + "\",";
  payload += "\"weather_desc\":\"" + weatherDesc + "\",";
  payload += "\"feels_like\":" + String((int)feelsLike) + ",";
  payload += "\"clouds\":" + String(cloudPercent) + ",";
  payload += "\"trigger\":\"" + trigger + "\"";
  payload += "}";

  int code = http.POST(payload);
  if (code == 200) {
    String body = http.getString();
    JSONVar resp = JSON.parse(body);
    if (JSON.typeof(resp) != "undefined") {
      applyAIResponse(resp, trigger);
      lastAiFetch = now;
    }
  }
  http.end();
}

void buildCalendarMarquee() {
  calendarMarqueeText = "";
  if (calEventCount <= 1) return;

  for (int i = 1; i < calEventCount; i++) {
    if (i > 1) calendarMarqueeText += "   |   ";
    calendarMarqueeText += calEvents[i].startTime;
    calendarMarqueeText += " ";
    calendarMarqueeText += calEvents[i].title;
  }
  calendarMarqueeText += "   |   ";
}

void drawMarqueeLine(String text, int y, int offset) {
  if (text.length() == 0) return;

  int charWidth = 6;
  int totalWidth = text.length() * charWidth;

  if (totalWidth <= SCREEN_WIDTH) {
    display.setCursor(0, y);
    display.print(text);
    return;
  }

  int startPixel = offset % totalWidth;

  for (int i = 0; i < text.length(); i++) {
    int x = i * charWidth - startPixel;
    if (x > SCREEN_WIDTH) break;
    if (x >= -charWidth) {
      display.setCursor(x, y);
      display.print(text[i]);
    }
  }

  for (int i = 0; i < text.length(); i++) {
    int x = i * charWidth - startPixel + totalWidth;
    if (x > SCREEN_WIDTH) break;
    if (x >= -charWidth) {
      display.setCursor(x, y);
      display.print(text[i]);
    }
  }
}

void fetchCalendarStatus() {
  if (WiFi.status() != WL_CONNECTED) {
    calendarAvailable = false;
    nextMeetingTitle = "No WiFi";
    nextMeetingStart = "";
    nextMeetingEnd = "";
    meetingMinutesLeft = -1;
    calEventCount = 0;
    return;
  }

  if (AI_SERVER.length() == 0) {
    calendarAvailable = false;
    nextMeetingTitle = "Server missing";
    nextMeetingStart = "";
    nextMeetingEnd = "";
    meetingMinutesLeft = -1;
    calEventCount = 0;
    return;
  }

  HTTPClient http;
  String url = AI_SERVER + "/deskmate-calendar";


  http.setTimeout(5000);
  http.begin(url);

  int code = http.GET();
  

  if (code > 0) {
    String body = http.getString();
   

    JSONVar resp = JSON.parse(body);

    if (JSON.typeof(resp) == "undefined") {
      
      calendarAvailable = false;
      nextMeetingTitle = "Bad JSON";
      nextMeetingStart = "";
      nextMeetingEnd = "";
      meetingMinutesLeft = -1;
      calEventCount = 0;
      http.end();
      return;
    }

    String status = "";
    if (resp.hasOwnProperty("status")) {
      status = (const char*)resp["status"];
    }

    if (status == "ok") {
      calendarAvailable = true;

      nextMeetingTitle = resp.hasOwnProperty("title")
                           ? String((const char*)resp["title"])
                           : "No title";

      nextMeetingStart = resp.hasOwnProperty("start_time")
                           ? String((const char*)resp["start_time"])
                           : "";

      nextMeetingEnd = resp.hasOwnProperty("end_time")
                         ? String((const char*)resp["end_time"])
                         : "";

      meetingState = resp.hasOwnProperty("meeting_state")
                       ? String((const char*)resp["meeting_state"])
                       : "unknown";

      meetingMinutesLeft = resp.hasOwnProperty("minutes_left")
                             ? int(resp["minutes_left"])
                             : -1;

      calEventCount = 0;

      if (resp.hasOwnProperty("events")) {
        JSONVar events = resp["events"];
        int total = events.length();
        if (total > 3) total = 3;

        for (int i = 0; i < total; i++) {
          calEvents[i].title = events[i].hasOwnProperty("title")
                                 ? String((const char*)events[i]["title"])
                                 : "Untitled";

          calEvents[i].startTime = events[i].hasOwnProperty("start_time")
                                     ? String((const char*)events[i]["start_time"])
                                     : "";

          calEvents[i].endTime = events[i].hasOwnProperty("end_time")
                                   ? String((const char*)events[i]["end_time"])
                                   : "";

          calEvents[i].state = events[i].hasOwnProperty("meeting_state")
                                 ? String((const char*)events[i]["meeting_state"])
                                 : "unknown";

          calEvents[i].minutesLeft = events[i].hasOwnProperty("minutes_left")
                                       ? int(events[i]["minutes_left"])
                                       : -1;

          calEventCount++;
        }
      }

      buildCalendarMarquee();
      marqueeOffset = 0;
      marqueePaused = false;
      marqueePauseStart = 0;
      applyCalendarMood();

    } else {
      calendarAvailable = false;
      nextMeetingTitle = resp.hasOwnProperty("title")
                           ? String((const char*)resp["title"])
                           : "Calendar unavailable";
      nextMeetingStart = "";
      nextMeetingEnd = "";
      meetingMinutesLeft = -1;
      calEventCount = 0;

      
    }
  } else {
    calendarAvailable = false;
    nextMeetingTitle = "Calendar unavailable";
    nextMeetingStart = "";
    nextMeetingEnd = "";
    meetingMinutesLeft = -1;
    calEventCount = 0;

  }

  http.end();
}

