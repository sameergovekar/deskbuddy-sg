LOCAL_TZ = datetime.datetime.now().astimezone().tzinfo


def get_google_calendar_service():
    creds = None

    if os.path.exists("token.json"):
        creds = Credentials.from_authorized_user_file("token.json", GCAL_SCOPES)

    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
        else:
            flow = InstalledAppFlow.from_client_secrets_file(
                "credentials.json", GCAL_SCOPES
            )
            creds = flow.run_local_server(port=0)

        with open("token.json", "w") as token:
            token.write(creds.to_json())

    return build("calendar", "v3", credentials=creds)


def simplify_event(event, now_dt):
    title = event.get("summary", "Untitled meeting")
    start_raw = event["start"].get("dateTime", event["start"].get("date"))
    end_raw = event["end"].get("dateTime", event["end"].get("date"))

    # Timed event
    if "T" in start_raw:
        start_dt = datetime.datetime.fromisoformat(start_raw.replace("Z", "+00:00"))
        end_dt = datetime.datetime.fromisoformat(end_raw.replace("Z", "+00:00"))

        start_local_dt = start_dt.astimezone(LOCAL_TZ)
        end_local_dt = end_dt.astimezone(LOCAL_TZ)

        minutes_left = int((start_local_dt - now_dt).total_seconds() / 60)

        if start_local_dt <= now_dt <= end_local_dt:
            state = "in_progress"
        elif 0 <= minutes_left <= 10:
            state = "starting_soon"
        else:
            state = "upcoming"

        return {
            "title": title,
            "start_time": start_local_dt.strftime("%H:%M"),
            "end_time": end_local_dt.strftime("%H:%M"),
            "minutes_left": minutes_left,
            "meeting_state": state,
            "start_iso": start_local_dt.isoformat(),
            "end_iso": end_local_dt.isoformat()
        }

    # All-day event
    return {
        "title": title,
        "start_time": start_raw,
        "end_time": end_raw,
        "minutes_left": -1,
        "meeting_state": "all_day",
        "start_iso": start_raw,
        "end_iso": end_raw
    }


def get_next_meeting():
    try:
        service = get_google_calendar_service()

        now_dt = datetime.datetime.now(LOCAL_TZ)
        now_utc = now_dt.astimezone(datetime.timezone.utc).isoformat()

        events_result = service.events().list(
            calendarId="primary",
            timeMin=now_utc,
            maxResults=3,
            singleEvents=True,
            orderBy="startTime",
        ).execute()

        events = events_result.get("items", [])

        if not events:
            return {
               "status": "ok",
                "meeting_state": "free",
                "title": "You're free",
                "start_time": "",
                "end_time": "",
                "minutes_left": -1,
                "events": []
            }

        simplified = [simplify_event(event, now_dt) for event in events]
        first = simplified[0]

        return {
            "status": "ok",
            "meeting_state": first["meeting_state"],
            "title": first["title"],
            "start_time": first["start_time"],
            "end_time": first["end_time"],
            "minutes_left": first["minutes_left"],
            "events": simplified
        }

    except Exception as e:
        print("GCAL ERROR:", e)
        return {
            "status": "error",
            "meeting_state": "unknown",
            "title": "Calendar unavailable",
            "start_time": "",
            "end_time": "",
            "minutes_left": -1,
            "events": []
        }
