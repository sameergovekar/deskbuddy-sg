def build_prompt(context):
    trigger = context["trigger"]

    if trigger == "boot":
        task = """
Generate a short startup greeting.
Do not mention rain unless the input weather is Rain or Drizzle.
"""
    elif trigger == "pomodoro_focus_start":
        task = """
Generate a short focus-start message.
It should feel energizing and work-oriented.
Do not mention weather unless it naturally fits.
"""
    elif trigger == "pomodoro_break_start":
        task = """
Generate a short break-start message.
It should feel relaxing and gentle.
Do not mention weather unless it naturally fits.
"""
    else:
        task = """
Generate a weather-refresh message.
STRICT:
- Never invent weather conditions.
- Must reflect weather exactly from the input.
- If weather is Clear, do not mention rain.
- If weather is Rain or Drizzle, do not mention clear skies.
- Prefer weather_desc, feels_like, humidity, and clouds for realism.
"""

    return f"""
You are DeskBuddy, a tiny desk companion robot.

{task}

GLOBAL RULES:
- Return ONE short message only
- Maximum 12 words
- Warm, natural, concise
- No emojis
- Return valid JSON only
- Allowed moods: normal, happy, sleepy, sad, excited, suspicious, surprised, love

Context:
City: {context['city']}
Weather: {context['weather']}
Weather description: {context['weather_desc']}
Temperature: {context['temp']} C
Feels like: {context['feels_like']} C
Humidity: {context['humidity']} %
Cloud cover: {context['clouds']} %
Time of day: {context['time_of_day']}
WiFi bars: {context['wifi_bars']}
Mode: {context['mode']}
Trigger: {context['trigger']}

Return exactly:
{{
  "message": "...",
  "mood": "..."
}}
"""


def parse_model_json(text: str):
    text = text.strip()

    if text.startswith("```"):
        lines = text.splitlines()
        lines = [ln for ln in lines if not ln.strip().startswith("```")]
        text = "\n".join(lines).strip()

    return json.loads(text)


def generate_ai_message(context):
    if not OPENAI_API_KEY:
        return {
            "status": "error",
            "message": "OPENAI_API_KEY not set",
            "mood": "normal",
            "show_seconds": 5
        }

    prompt = build_prompt(context)

    try:
        completion = client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {
                    "role": "system",
                    "content": "You are a tiny desk robot assistant. Be concise, contextual, and literal about weather."
                },
                {
                    "role": "user",
                    "content": prompt
                }
            ],
            temperature=0.3
        )

        text = completion.choices[0].message.content or ""
        result = parse_model_json(text)

        mood = clean_mood(result.get("mood", "normal"))
        message = (result.get("message", "") or "").strip()

        if not message:
            return fallback_message(context)

        if len(message) > 80:
            message = message[:80].rstrip()

        return {
            "status": "ok",
            "message": message,
            "mood": mood,
            "show_seconds": 8
        }

    except Exception as e:
        print("AI ERROR:", e)
        return fallback_message(context)


