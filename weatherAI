VALID_MOODS = [
    "normal",
    "happy",
    "sleepy",
    "sad",
    "excited",
    "suspicious",
    "surprised",
    "love"
]


def get_time_bucket():
    h = datetime.datetime.now().hour
    if 5 <= h < 12:
        return "morning"
    elif 12 <= h < 17:
        return "afternoon"
    elif 17 <= h < 21:
        return "evening"
    else:
        return "night"


def clean_mood(value: str) -> str:
    mood = (value or "normal").strip().lower()
    return mood if mood in VALID_MOODS else "normal"


